// In ProUpgradeModal.tsx
import { initializePayment, PRO_PLANS, ProPlan } from '../services/paystackService';

// Inside the component, replace handleUpgrade:
const handleUpgrade = async () => {
  if (isPro) {
    onClose();
    return;
  }

  setProcessing(true);
  setError('');

  try {
    const result = await initializePayment(userEmail, selectedPlan, userId);

    if (result.success && result.paymentUrl) {
      // Redirect to Paystack checkout page
      window.location.href = result.paymentUrl;
    } else {
      throw new Error(result.error || 'Payment initialization failed');
    }
  } catch (err: any) {
    console.error('❌ Upgrade error:', err.message);
    setError(err.message || 'Payment failed. Please try again.');
    setProcessing(false);
  }
};


