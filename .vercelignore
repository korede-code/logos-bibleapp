const allowedOrigins = [
  'http://localhost:5173',
  'https://logos-daily.web.app',
  'https://logos-daily.firebaseapp.com',
  'https://app.logosdaily.com' // Your custom domain
];

app.use(cors({
  origin: function (origin, callback) {
    if (!origin) return callback(null, true);
    if (allowedOrigins.indexOf(origin) !== -1) {
      callback(null, true);
    } else {
      callback(new Error('Not allowed by CORS'));
    }
  },
  credentials: true
}));


// In SettingsScreen.tsx
const SettingsScreen: React.FC = () => {
  const { readerSettings, navigate, isPro, currentUser, setCurrentUser, setProStatus, logout } = useAppStore();
  const theme = getTheme(readerSettings.theme);
  const [showAuthModal, setShowAuthModal] = useState(false);
  const [showProModal, setShowProModal] = useState(false);
  
  // Listen to auth state changes
  useEffect(() => {
    const unsubscribe = onAuthStateChanged(auth, async (user) => {
      if (user) {
        // Check if user has pro status
        const savedProStatus = localStorage.getItem(`isPro_${user.uid}`) === 'true';
        setCurrentUser(user);
        setProStatus(savedProStatus);
      } else {
        setCurrentUser(null);
        setProStatus(false);
      }
    });
    return () => unsubscribe();
  }, [setCurrentUser, setProStatus]);
  
  // ... rest of component
};